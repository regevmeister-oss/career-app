generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // לפיתוח
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  isPro     Boolean  @default(false)
  createdAt DateTime @default(now())
}