generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  isPro    Boolean @default(false)
}
model Analysis {
  id        String   @id @default(cuid())
  userId    String
  result    String
  createdAt DateTime @default(now())
}