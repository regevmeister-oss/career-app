generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  analyses  Analysis[]
}

model Analysis {
  id        String   @id @default(cuid())
  userId    String
  result    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
